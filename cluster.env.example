# cluster.env — Site-specific variables for the k3s-ansible deployment.
#
# Copy this file to cluster.env and fill in every value.
# cluster.env is gitignored — never commit it.
#
# Usage:
#   cp cluster.env.example cluster.env
#   $EDITOR cluster.env
#   bash scripts/apply-vars.sh    # substitutes values into gitops YAML files
#   bash scripts/seal-secrets.sh  # encrypts secrets before committing

# ── Git repository ────────────────────────────────────────────────────────────
# Required for ArgoCD to pull manifests. Leave credentials blank for public repos.
GITOPS_REPO_URL="https://git.example.com/homelab/k3s-ansible.git"
GITOPS_REPO_USERNAME=""
GITOPS_REPO_TOKEN=""

# ── Blob storage (MinIO / S3-compatible external NAS) ─────────────────────────
# Used by: barman-cloud (PostgreSQL WAL archiving) and MariaDB backup.
BLOB_STORAGE_ENDPOINT="http://192.168.1.10:9000"
BLOB_ACCESS_KEY_ID="minioadmin"
BLOB_SECRET_ACCESS_KEY="CHANGE_ME"

# ── Database passwords ────────────────────────────────────────────────────────
# DB_SUPERUSER_PASSWORD → pgc1-superuser Secret (Postgres) + dbcreds (cw user)
# DB_KEYCLOAK_PASSWORD  → Keycloak postgres role + keycloak-postgres-secret
DB_SUPERUSER_PASSWORD="CHANGE_ME"
DB_KEYCLOAK_PASSWORD="CHANGE_ME"

# ── Cloudflare ────────────────────────────────────────────────────────────────
# DNS-01 challenge token for cert-manager (Zones:Read, DNS:Edit permissions).
CLOUDFLARE_TOKEN="CHANGE_ME"

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD="CHANGE_ME"

# ── Grafana ───────────────────────────────────────────────────────────────────
# GRAFANA_OIDC_CLIENT_SECRET → create the 'grafana' client in Keycloak first,
# then copy the client secret here and re-run apply-vars.sh + seal-secrets.sh.
GRAFANA_ADMIN_PASSWORD="CHANGE_ME"
GRAFANA_OIDC_CLIENT_SECRET="CHANGE_ME"

# ── Gitea read-only token ─────────────────────────────────────────────────────
# Used by the Keycloak theme loader init container to pull themes from Gitea.
GITEA_READONLY_USERNAME="CHANGE_ME"
GITEA_READONLY_TOKEN="CHANGE_ME"
